# Google Sheets — lista de precios
# Creá una Service Account en Google Cloud y pegá el JSON completo acá
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# ID de la planilla (está en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
GOOGLE_SHEETS_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# Resend — notificaciones de email
RESEND_API_KEY=re_...
# Email que va a recibir los avisos de turnos
NOTIFICATION_EMAIL=turnos@moscatoneumaticos.com.ar

# Upstash Redis — historial de conversación
# Gratis en upstash.com → Redis → Create Database
UPSTASH_REDIS_REST_URL=https://....upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Seguridad: clave secreta para verificar que el request viene de ManyChat
WEBHOOK_SECRET=una-clave-secreta-que-vos-elijas
